# Copy to configs/secrets.local.env and fill the empty values.
# Source it before starting Joi:
#   set -a; source configs/secrets.local.env; set +a

DEEPSEEK_API_KEY=

# Optional for Telegram real check.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
PUBLIC_CONSOLE_URL=
PUBLIC_BASE_URL=
CONSOLE_BASE_URL=
ADMIN_TOKEN=

# Optional for vps-la-1.
NODE_SECRET=
WORKER_TOKEN=
WORKER_ALLOWED_NODE_IDS=local-worker-1,vps-la-1

# Remote worker process only. Do not source this in the Mac main-node stack.
# WORKER_GATEWAY_URL=http://127.0.0.1:18081
